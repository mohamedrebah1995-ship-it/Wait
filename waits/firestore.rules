rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      // Personal earnings log — strictly private to that driver
      match /earnings/{earningId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      // Shift clock-in/out records — strictly private to that driver
      match /shifts/{shiftId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    // Wait logs — any authenticated user can read/write
    match /waitLogs/{logId} {
      allow read, write: if request.auth != null;
    }
    // Location votes (Manual Arrive) — authenticated users can read/create
    match /locationVotes/{voteId} {
      allow read, create: if request.auth != null;
    }
    // Crowd-sourced pinned restaurant locations
    match /restaurantLocations/{restaurantId} {
      allow read, write: if request.auth != null;
    }
    // Driver-reported "drivers waiting now" counts (latest per restaurant, 20-min TTL on read)
    match /restaurantCounts/{restaurantId} {
      allow read, write: if request.auth != null;
    }
    // Area-specific long-queue alerts (latest per restaurant per area, 20-min TTL on read)
    match /queueAlerts/{alertId} {
      allow read, write: if request.auth != null;
    }
    // Live "waiting now" presence — anyone reads, you only write your own
    match /activeWaits/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
    // Driver roster (for the live driver count) — read by all, you only write your own (no PII stored)
    match /drivers/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
    // Area chat rooms (subcollections) — any authenticated user can read/write
    match /chats/{room}/messages/{messageId} {
      allow read, write: if request.auth != null;
    }
    // Legacy messages collection
    match /messages/{messageId} {
      allow read, write: if request.auth != null;
    }
  }
}
