rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // Wait logs — any authenticated user can read/write
    match /waitLogs/{logId} {
      allow read, write: if request.auth != null;
    }
    // Area chat rooms (subcollections) — any authenticated user can read/write
    match /chats/{room}/messages/{messageId} {
      allow read, write: if request.auth != null;
    }
    // Legacy messages collection
    match /messages/{messageId} {
      allow read, write: if request.auth != null;
    }
  }
}
